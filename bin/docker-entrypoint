#!/bin/bash -e

# If running the rails server then create or migrate existing database
# Support both "./bin/rails server" and "bundle exec rails server"
if ([ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]) || \
   ([ "${@: -2:1}" == "rails" ] && [ "${@: -1:1}" == "server" ]); then
  ./bin/rails db:prepare
fi

exec "${@}"
