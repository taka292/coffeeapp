<% content_for :title, "設定" %>

<div class="-mt-28 -mx-5 min-h-screen w-screen bg-[#f6f1ec] text-[#2e2a26]">
  <div class="mx-auto flex min-h-screen w-full max-w-[375px] flex-col">
    <%# ヘッダー %>
    <header class="sticky top-0 z-20 flex items-center justify-between bg-[#f6f1ec] px-5 pt-4 pb-2">
      <div class="h-11 w-11"></div>
      <h1 class="text-base font-bold">設定</h1>
      <div class="h-11 w-11"></div>
    </header>

    <%# メインコンテンツ %>
    <main class="flex-1 space-y-4 px-5 pt-2 pb-6">
      <%# ユーザープロフィールカード %>
      <div class="rounded-xl border border-black/10 bg-white p-5 shadow-[0_4px_20px_rgba(0,0,0,0.03)]">
        <div class="flex items-center gap-4">
          <div class="flex h-14 w-14 items-center justify-center rounded-full bg-[#e6d6c8] text-2xl">
            👤
          </div>
          <div class="flex-1">
            <% if user_signed_in? %>
              <p class="text-lg font-bold text-[#2e2a26]"><%= current_user.name %></p>
              <p class="text-sm text-[#9a8f88]"><%= current_user.email %></p>
            <% else %>
              <p class="text-lg font-bold text-[#2e2a26]">ゲスト</p>
              <p class="text-sm text-[#9a8f88]">ログインしていません</p>
            <% end %>
          </div>
        </div>
      </div>

      <%# アカウント設定セクション %>
      <div class="rounded-xl border border-black/10 bg-white p-5 shadow-[0_4px_20px_rgba(0,0,0,0.03)]">
        <h2 class="mb-4 text-sm font-bold text-[#9a8f88]">アカウント</h2>
        
        <div class="space-y-3">
          <% if user_signed_in? %>
            <%# ログイン中の場合 %>
            <%= link_to edit_user_registration_path, class: "flex items-center justify-between rounded-lg border border-[#e6d6c8] bg-white p-4 transition-all hover:bg-[#f6f1ec]" do %>
              <div class="flex items-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-[#e6d6c8]">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#6b3f2b]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                </div>
                <span class="font-bold text-[#2e2a26]">プロフィール編集</span>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#9a8f88]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            <% end %>

            <%# ログアウトボタン %>
            <%= button_to destroy_user_session_path, method: :delete, class: "flex w-full items-center justify-between rounded-lg border border-[#e6d6c8] bg-white p-4 transition-all hover:bg-red-50" do %>
              <div class="flex items-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-red-100">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                  </svg>
                </div>
                <span class="font-bold text-red-500">ログアウト</span>
              </div>
            <% end %>
          <% else %>
            <%# 未ログインの場合 %>
            <%= link_to new_user_session_path, class: "flex items-center justify-between rounded-lg border border-[#e6d6c8] bg-white p-4 transition-all hover:bg-[#f6f1ec]" do %>
              <div class="flex items-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-[#e6d6c8]">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#6b3f2b]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" />
                  </svg>
                </div>
                <span class="font-bold text-[#2e2a26]">ログイン</span>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#9a8f88]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            <% end %>

            <%= link_to new_user_registration_path, class: "flex items-center justify-between rounded-lg border border-[#6b3f2b] bg-[#6b3f2b] p-4 transition-all hover:bg-[#5a3524]" do %>
              <div class="flex items-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-white/20">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
                  </svg>
                </div>
                <span class="font-bold text-white">新規会員登録</span>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            <% end %>
          <% end %>
        </div>
      </div>

    </main>

    <%# ボトムナビゲーション %>
    <nav class="sticky bottom-0 z-20 flex h-16 items-center justify-around border-t border-black/10 bg-white shadow-[0_-4px_12px_rgba(0,0,0,0.02)]">
      <%= link_to root_path, class: "flex flex-1 flex-col items-center justify-center gap-1" do %>
        <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-[#e6d6c8]">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0 text-[#6b3f2b]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
        </div>
        <span class="text-[10px] font-bold text-[#9a8f88]">ホーム</span>
      <% end %>
      <%= link_to coffee_records_path, class: "flex flex-1 flex-col items-center justify-center gap-1" do %>
        <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-[#e6d6c8]">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0 text-[#6b3f2b]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
          </svg>
        </div>
        <span class="text-[10px] font-bold text-[#9a8f88]">記録一覧</span>
      <% end %>
      <div class="relative -top-3 flex flex-1 items-center justify-center">
        <button class="flex h-[52px] w-[52px] items-center justify-center rounded-full bg-[#6b3f2b] text-2xl text-white shadow-[0_4px_12px_rgba(107,63,43,0.3)]">
          +
        </button>
      </div>
      <div class="flex flex-1 flex-col items-center justify-center gap-1 text-[#9a8f88]">
        <span class="text-lg">📈</span>
        <span class="text-[10px] font-bold">データ</span>
      </div>
      <%= link_to settings_path, class: "flex flex-1 flex-col items-center justify-center gap-1 text-[#6b3f2b]" do %>
        <span class="text-lg">👤</span>
        <span class="text-[10px] font-bold">設定</span>
      <% end %>
    </nav>
  </div>
</div>
