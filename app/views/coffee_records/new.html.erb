<% content_for :title, "抽出条件" %>
<% content_for :head do %>
  <script src="https://code.iconify.design/iconify-icon/3.0.0/iconify-icon.min.js"></script>
<% end %>
<%
  use_default_values = @coffee_record.new_record? && @coffee_record.errors.empty?
  bean_name_value = use_default_values ? (@coffee_record.bean_name.presence || "エチオピア イルガチェフェ") : @coffee_record.bean_name
  grind_size_value = use_default_values ? (@coffee_record.grind_size || 34) : @coffee_record.grind_size
  bean_amount_value = use_default_values ? (@coffee_record.bean_amount || 18) : @coffee_record.bean_amount
  water_temperature_value = use_default_values ? (@coffee_record.water_temperature || 92) : @coffee_record.water_temperature
  water_amount_value = use_default_values ? (@coffee_record.water_amount || 260) : @coffee_record.water_amount
  brew_time_total = use_default_values ? (@coffee_record.brew_time || 155) : @coffee_record.brew_time.to_i
  brew_minute_value = ((@coffee_record.brew_minute.presence || (brew_time_total / 60))).to_i
  brew_second_value = ((@coffee_record.brew_second.presence || (brew_time_total % 60))).to_i
%>

<div class="-mt-28 -mx-5 min-h-screen w-screen bg-[#f6f1ec] font-sans text-[#2e2a26]">
  <div class="mx-auto flex min-h-screen w-full max-w-[375px] flex-col" data-controller="brew-setup">
    <header class="flex shrink-0 items-center justify-between bg-[#f6f1ec] px-5 pt-4 pb-2">
      <%= link_to coffee_records_path, class: "flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-white text-[#2e2a26] shadow-[0_2px_8px_rgba(0,0,0,0.04)]" do %>
        <iconify-icon icon="lucide:chevron-left" class="text-xl" style="color: #2e2a26"></iconify-icon>
      <% end %>
      <h1 class="text-base font-bold text-[#2e2a26]">抽出条件</h1>
      <div class="h-11 w-11 shrink-0" aria-hidden="true"></div>
    </header>

    <%= form_with model: @coffee_record, url: coffee_records_path, class: "flex min-h-0 flex-1 flex-col" do |f| %>
      <div class="flex min-h-0 flex-1 flex-col gap-5 overflow-y-auto px-5 pt-2 pb-36">
        <% if @coffee_record.errors.any? %>
          <div class="rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-700">
            <p class="font-semibold">入力内容を確認してください</p>
            <ul class="mt-1 list-disc pl-5">
              <% @coffee_record.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="flex flex-col gap-2 pt-1">
          <p class="text-[13px] font-semibold text-[#646464]">STEP 1 / 2</p>
        </div>

        <section class="flex flex-col gap-3">
          <h3 class="flex items-center gap-2 text-base font-bold text-[#6b3f2b]"><span class="h-[18px] w-1 shrink-0 rounded-full bg-[#c77a4a]"></span>豆の情報</h3>
          <div class="flex flex-col gap-4 rounded-lg bg-white p-4 shadow-[0_4px_14px_rgba(0,0,0,0.04)]">
            <div class="flex flex-col gap-2.5">
              <div class="flex flex-col gap-1">
                <label class="text-[15px] font-semibold text-[#292929]" for="coffee_record_bean_name">使用した豆の名前</label>
                <p class="text-[13px] leading-snug text-[#646464]">豆袋の名前や産地をそのまま入力</p>
              </div>
              <div class="flex min-h-[52px] items-center justify-between gap-3 rounded-md bg-[#f1e9e2] px-4 py-3.5">
                <%= f.text_field :bean_name, autocomplete: "off", placeholder: "例: エチオピア イルガチェフェ", class: "min-w-0 flex-1 border-0 bg-transparent text-[15px] font-medium text-[#292929] placeholder:text-[#646464] focus:outline-none focus:ring-0" %>
                <iconify-icon icon="lucide:pencil" class="shrink-0 text-lg" style="color: #646464"></iconify-icon>
              </div>
            </div>

            <div class="flex flex-col gap-2.5">
              <div class="flex items-start justify-between gap-3">
                <div class="min-w-0 flex-1">
                  <p class="text-[15px] font-semibold text-[#292929]">豆の挽き目の粗さ</p>
                  <p class="text-[13px] leading-snug text-[#646464]">1が細かめ、50が粗め</p>
                </div>
                <span data-brew-setup-target="grindValue" class="shrink-0 rounded-xl bg-[#e6d6c8] px-2.5 py-1.5 text-[13px] font-bold text-[#6b3f2b]"><%= grind_size_value %></span>
              </div>
              <div class="flex flex-col gap-3">
                <div class="relative px-2 pt-1">
                  <div class="relative h-8 w-full">
                    <div class="pointer-events-none absolute inset-x-0 top-1/2 h-2 -translate-y-1/2 rounded-full bg-[#e6d6c8]"></div>
                    <div data-brew-setup-target="grindFill" class="pointer-events-none absolute left-0 top-1/2 h-2 -translate-y-1/2 rounded-full bg-[#c77a4a]" style="width: 67.35%"></div>
                    <%= f.range_field :grind_size, value: grind_size_value, min: 1, max: 50, data: { brew_setup_target: "grindRange", action: "input->brew-setup#grindChanged" }, class: "absolute inset-x-0 top-0 z-10 h-8 w-full cursor-pointer appearance-none bg-transparent opacity-100 [&::-webkit-slider-thumb]:h-[22px] [&::-webkit-slider-thumb]:w-[22px] [&::-webkit-slider-thumb]:cursor-pointer [&::-webkit-slider-thumb]:appearance-none [&::-webkit-slider-thumb]:rounded-full [&::-webkit-slider-thumb]:border-4 [&::-webkit-slider-thumb]:border-[#c77a4a] [&::-webkit-slider-thumb]:bg-white [&::-webkit-slider-thumb]:shadow-[0_2px_8px_rgba(199,122,74,0.18)] [&::-moz-range-thumb]:h-[22px] [&::-moz-range-thumb]:w-[22px] [&::-moz-range-thumb]:cursor-pointer [&::-moz-range-thumb]:rounded-full [&::-moz-range-thumb]:border-4 [&::-moz-range-thumb]:border-[#c77a4a] [&::-moz-range-thumb]:bg-white" %>
                  </div>
                </div>
                <div class="flex justify-between px-2 text-[13px] font-semibold text-[#646464]">
                  <span>1</span><span>25</span><span>50</span>
                </div>
                <div class="flex items-center justify-between gap-3 text-[13px] text-[#646464]">
                  <span data-brew-setup-target="grindHint">中細挽きに近い設定</span>
                  <span data-brew-setup-target="grindPill" class="rounded-xl bg-[#e6d6c8] px-2.5 py-1.5 text-[13px] font-bold text-[#6b3f2b]"><%= grind_size_value %> / 50</span>
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="flex flex-col gap-3">
          <h3 class="flex items-center gap-2 text-base font-bold text-[#6b3f2b]"><span class="h-[18px] w-1 shrink-0 rounded-full bg-[#c77a4a]"></span>レシピ</h3>
          <div class="flex flex-col gap-3 rounded-lg bg-white p-4 shadow-[0_4px_14px_rgba(0,0,0,0.04)]">
            <div class="grid grid-cols-2 gap-3">
              <label class="flex min-h-[88px] flex-col gap-2 rounded-md bg-[#f1e9e2] px-3.5 py-3.5">
                <span class="text-[13px] font-semibold text-[#646464]">豆の量</span>
                <span class="flex items-center justify-between gap-2">
                  <span class="flex items-baseline gap-0.5">
                    <%= f.select :bean_amount,
                                 options_for_select((10..30).to_a.map { |v| ["#{v}g", v] }, bean_amount_value),
                                 {},
                                 data: { brew_setup_target: "beanAmount", action: "change->brew-setup#ratioChanged" },
                                 class: "w-20 border-0 bg-transparent text-lg font-bold text-[#292929] focus:outline-none focus:ring-0" %>
                  </span>
                </span>
              </label>

              <label class="flex min-h-[88px] flex-col gap-2 rounded-md bg-[#f1e9e2] px-3.5 py-3.5">
                <span class="text-[13px] font-semibold text-[#646464]">温度</span>
                <span class="flex items-center justify-between gap-2">
                  <span class="flex items-baseline gap-0.5">
                    <%= f.select :water_temperature,
                                 options_for_select((85..96).to_a.map { |v| ["#{v}℃", v] }, water_temperature_value),
                                 {},
                                 class: "w-20 border-0 bg-transparent text-lg font-bold text-[#292929] focus:outline-none focus:ring-0" %>
                  </span>
                </span>
              </label>
            </div>

            <div class="grid grid-cols-2 gap-3">
              <div class="flex min-h-[88px] flex-col gap-2 rounded-md bg-[#f1e9e2] px-3.5 py-3.5">
                <span class="text-[13px] font-semibold text-[#646464]">抽出時間</span>
                <span class="flex items-center justify-between gap-2">
                  <span class="sr-only" data-brew-setup-target="brewTimeDisplay"><%= format("%02d:%02d", brew_minute_value, brew_second_value) %></span>
                  <span class="flex items-center gap-0.5 text-lg font-bold tabular-nums text-[#292929]" aria-hidden="true">
                    <%= number_field_tag "coffee_record[brew_minute]", brew_minute_value, min: 0, data: { brew_setup_target: "brewMinute", action: "input->brew-setup#brewTimeChanged" }, class: "w-9 border-0 bg-transparent p-0 text-right text-lg font-bold [appearance:textfield] focus:outline-none focus:ring-0 [&::-webkit-inner-spin-button]:appearance-none [&::-webkit-outer-spin-button]:appearance-none" %>
                    <span>:</span>
                    <%= number_field_tag "coffee_record[brew_second]", brew_second_value, min: 0, max: 59, data: { brew_setup_target: "brewSecond", action: "input->brew-setup#brewTimeChanged" }, class: "w-9 border-0 bg-transparent p-0 text-left text-lg font-bold [appearance:textfield] focus:outline-none focus:ring-0 [&::-webkit-inner-spin-button]:appearance-none [&::-webkit-outer-spin-button]:appearance-none" %>
                  </span>
                  <iconify-icon icon="lucide:timer-reset" class="text-lg shrink-0" style="color: #646464"></iconify-icon>
                </span>
              </div>

              <label class="flex min-h-[88px] flex-col gap-2 rounded-md bg-[#f1e9e2] px-3.5 py-3.5">
                <span class="text-[13px] font-semibold text-[#646464]">湯量</span>
                <span class="flex items-center justify-between gap-2">
                  <span class="flex items-baseline gap-0.5">
                    <%= f.number_field :water_amount, value: water_amount_value, min: 1, max: 999, step: 1, data: { brew_setup_target: "waterAmount", action: "input->brew-setup#ratioChanged" }, class: "w-16 border-0 bg-transparent text-lg font-bold text-[#292929] [appearance:textfield] focus:outline-none focus:ring-0 [&::-webkit-inner-spin-button]:appearance-none [&::-webkit-outer-spin-button]:appearance-none" %>
                    <span class="text-lg font-bold text-[#292929]">ml</span>
                  </span>
                  <iconify-icon icon="lucide:droplets" class="text-lg shrink-0" style="color: #646464"></iconify-icon>
                </span>
              </label>
            </div>

            <div class="flex items-center justify-between gap-3 rounded-md bg-white px-3.5 py-3 shadow-[0_1px_0_rgba(0,0,0,0.02)] ring-1 ring-black/5">
              <div class="flex min-w-0 items-center gap-2.5">
                <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[#c77a4a] text-[13px] font-bold text-white">1</div>
                <div class="min-w-0">
                  <p class="truncate text-sm font-bold text-[#292929]">抽出比率の目安</p>
                  <p data-brew-setup-target="ratioLine" class="truncate text-[13px] text-[#646464]"></p>
                </div>
              </div>
              <iconify-icon icon="lucide:badge-info" class="shrink-0 text-lg" style="color: #646464"></iconify-icon>
            </div>
          </div>
        </section>

        <section class="flex flex-col gap-3">
          <h3 class="flex items-center gap-2 text-base font-bold text-[#6b3f2b]"><span class="h-[18px] w-1 shrink-0 rounded-full bg-[#c77a4a]"></span>メモ</h3>
          <div class="rounded-lg bg-white p-4 shadow-[0_4px_14px_rgba(0,0,0,0.04)]">
            <label class="sr-only" for="coffee_record_brew_memo">淹れ方メモ</label>
            <%= f.text_area :brew_memo, rows: 4, placeholder: "蒸らしや注ぎ方など、覚えておきたいことをメモ", class: "min-h-[92px] w-full resize-y rounded-md bg-[#f1e9e2] px-4 py-3.5 text-[15px] leading-relaxed text-[#292929] placeholder:text-[#646464] focus:outline-none focus:ring-2 focus:ring-[#c77a4a]/30" %>
          </div>
        </section>
      </div>

      <div class="pointer-events-none fixed inset-x-0 bottom-0 z-10 flex justify-center bg-gradient-to-t from-[#f6f1ec] from-[78%] to-transparent pb-6 pt-12">
        <div class="pointer-events-auto w-full max-w-[375px] px-5">
          <%= f.button type: :submit, class: "flex h-14 w-full items-center justify-center gap-2 rounded-xl bg-[#6b3f2b] text-base font-bold text-white shadow-[0_10px_24px_rgba(107,63,43,0.22)]" do %>
            味の記録へ進む
            <iconify-icon icon="lucide:arrow-right" class="text-lg" style="color: #ffffff"></iconify-icon>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
