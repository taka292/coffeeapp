<div
  class="flex cursor-pointer flex-col rounded-2xl border border-[#e8e3dd] bg-white p-4 text-left shadow-[0_4px_20px_rgba(0,0,0,0.03)] touch-manipulation outline-none focus-visible:ring-2 focus-visible:ring-[#c77a4a]/40"
  role="button"
  tabindex="0"
  data-action="click->record-action-sheet#open keydown.enter->record-action-sheet#open keydown.space->record-action-sheet#open"
  data-record-action-sheet-edit-url="<%= edit_coffee_record_path(coffee_record) %>"
  data-record-action-sheet-delete-url="<%= coffee_record_path(coffee_record) %>"
  data-record-action-sheet-record-name="<%= h(coffee_record.bean_name) %>"
  aria-label="<%= h(coffee_record.bean_name) %>の操作メニューを開く"
>
  <div class="mb-4 flex flex-col gap-1.5">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-1.5 text-xs font-bold text-[#9a8f88]">
        <iconify-icon icon="lucide:calendar-clock" class="text-sm" style="color: #9a8f88"></iconify-icon>
        <%= coffee_record.created_at.strftime("%Y.%m.%d %H:%M") %>
      </div>
    </div>
    <h2 class="text-lg font-extrabold leading-snug text-[#6b3f2b]"><%= coffee_record.bean_name %></h2>
  </div>

  <p class="mb-3 text-xs font-bold text-[#9a8f88]">抽出レシピ</p>
  <div class="flex flex-wrap gap-x-4 gap-y-2.5 text-sm font-semibold text-[#2e2a26]">
    <div class="flex items-center gap-1.5">
      <iconify-icon icon="lucide:settings-2" class="shrink-0 text-sm" style="color: #9a8f88"></iconify-icon>
      <span>挽き目 <%= coffee_record.grind_size %></span>
    </div>
    <div class="flex items-center gap-1.5">
      <iconify-icon icon="lucide:coffee" class="shrink-0 text-sm" style="color: #9a8f88"></iconify-icon>
      <span><%= coffee_record.bean_amount %>g</span>
    </div>
    <div class="flex items-center gap-1.5">
      <iconify-icon icon="lucide:thermometer" class="shrink-0 text-sm" style="color: #9a8f88"></iconify-icon>
      <span><%= coffee_record.water_temperature %>℃</span>
    </div>
    <div class="flex items-center gap-1.5">
      <iconify-icon icon="lucide:timer" class="shrink-0 text-sm" style="color: #9a8f88"></iconify-icon>
      <span><%= coffee_record.brew_time_mmss %></span>
    </div>
    <div class="flex items-center gap-1.5">
      <iconify-icon icon="lucide:droplets" class="shrink-0 text-sm" style="color: #9a8f88"></iconify-icon>
      <span><%= coffee_record.water_amount %>ml</span>
    </div>
  </div>

  <div class="my-4 h-px bg-[#e8e3dd]/80"></div>

  <div class="flex gap-5">
    <div class="min-w-0 flex-1">
      <p class="mb-3 text-xs font-bold text-[#9a8f88]">味のバランス</p>
      <div class="flex justify-between gap-1">
        <% [
          [:acidity, "酸味"],
          [:bitterness, "苦味"],
          [:sweetness, "甘み"],
          [:body, "コク"],
          [:off_flavor, "雑味"]
        ].each do |attr, label| %>
          <div class="flex min-w-0 flex-1 flex-col items-center gap-2">
            <div class="relative h-12 w-2 overflow-hidden rounded-full bg-[#efebe7]">
              <div
                class="absolute bottom-0 left-0 right-0 rounded-full bg-[#d4a373]"
                style="height: <%= taste_bar_height_percent(coffee_record.public_send(attr)) %>%"
              ></div>
            </div>
            <span class="text-center text-[11px] font-bold leading-tight text-[#9a8f88]"><%= label %></span>
          </div>
        <% end %>
      </div>
    </div>
    <div class="w-[120px] shrink-0">
      <p class="mb-3 text-xs font-bold text-[#9a8f88]">フレーバー</p>
      <div class="rounded-md border border-dashed border-[#e6d6c8] bg-[#f9f6f0] px-2 py-3 text-center text-[11px] font-semibold leading-snug text-[#9a8f88]">
        準備中
      </div>
    </div>
  </div>

  <% if coffee_record.brew_memo.present? || coffee_record.comment.present? %>
    <div class="my-4 h-px bg-[#e8e3dd]/80"></div>
    <div class="flex flex-col gap-2">
      <% if coffee_record.brew_memo.present? %>
        <div class="flex gap-2.5 rounded-md bg-[#efebe7] p-3 text-[13px] leading-relaxed text-[#2e2a26]">
          <span class="mt-0.5 flex h-4 w-4 shrink-0 items-center justify-center">
            <iconify-icon icon="lucide:droplets" class="text-base" style="color: #7a726a"></iconify-icon>
          </span>
          <p class="min-w-0 flex-1 whitespace-pre-wrap"><%= coffee_record.brew_memo %></p>
        </div>
      <% end %>
      <% if coffee_record.comment.present? %>
        <div class="flex gap-2.5 rounded-md bg-[#efebe7] p-3 text-[13px] leading-relaxed text-[#2e2a26]">
          <span class="mt-0.5 flex h-4 w-4 shrink-0 items-center justify-center">
            <iconify-icon icon="lucide:message-square" class="text-base" style="color: #7a726a"></iconify-icon>
          </span>
          <p class="min-w-0 flex-1 whitespace-pre-wrap"><%= coffee_record.comment %></p>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
