<% content_for :title, "記録一覧" %>

<div class="-mt-28 -mx-5 min-h-screen w-screen bg-[#f6f1ec] text-[#2e2a26]">
  <div class="mx-auto flex min-h-screen w-full max-w-[375px] flex-col">
    <header class="sticky top-0 z-20 flex items-center justify-between bg-[#f6f1ec] px-5 pt-4 pb-2">
      <div class="h-11 w-11"></div>
      <h1 class="text-base font-bold">記録一覧</h1>
      <%= link_to settings_path, class: "flex h-11 w-11 items-center justify-center rounded-full border border-black/10 bg-white text-lg shadow-sm" do %>
        ⚙️
      <% end %>
    </header>

    <main class="flex-1 space-y-4 px-5 pt-2 pb-6">
      <article class="rounded-lg border border-black/10 bg-white p-4 shadow-[0_4px_20px_rgba(0,0,0,0.03)]">
        <div class="mb-4 space-y-1.5">
          <p class="text-xs font-bold text-[#9a8f88]">2023.10.24 08:30</p>
          <h2 class="text-lg font-extrabold text-[#6b3f2b]">エチオピア イルガチェフェ</h2>
        </div>

        <p class="mb-3 text-xs font-bold text-[#9a8f88]">抽出レシピ</p>
        <div class="flex flex-wrap gap-x-4 gap-y-2 text-sm font-semibold">
          <p>挽き目 34</p>
          <p>18g</p>
          <p>92℃</p>
          <p>02:35</p>
          <p>260ml</p>
        </div>

        <div class="my-4 h-px bg-black/10"></div>

        <div class="flex gap-5">
          <section class="flex-1">
            <p class="mb-3 text-xs font-bold text-[#9a8f88]">味のバランス</p>
            <div class="flex justify-between">
              <% [["酸味", "80%"], ["苦味", "30%"], ["甘み", "70%"], ["とろみ", "50%"], ["雑味", "20%"]].each do |label, height| %>
                <div class="flex flex-1 flex-col items-center gap-2">
                  <div class="relative h-12 w-2 overflow-hidden rounded-full bg-[#e6d6c8]">
                    <div class="absolute bottom-0 left-0 right-0 rounded-full bg-[#c77a4a]" style="height: <%= height %>"></div>
                  </div>
                  <p class="text-[11px] font-bold text-[#9a8f88]"><%= label %></p>
                </div>
              <% end %>
            </div>
          </section>

          <section class="w-[120px]">
            <p class="mb-3 text-xs font-bold text-[#9a8f88]">フレーバー</p>
            <div class="flex flex-wrap gap-1.5">
              <% ["ラズベリー", "チョコ", "花"].each do |flavor| %>
                <span class="rounded bg-[#e6d6c8] px-2 py-1 text-xs font-bold text-[#6b3f2b]"><%= flavor %></span>
              <% end %>
            </div>
          </section>
        </div>

        <div class="my-4 h-px bg-black/10"></div>

        <div class="space-y-2">
          <p class="rounded-md bg-[#e6d6c8] p-3 text-sm leading-relaxed">
            1投目はややゆっくり、中心から外に2周。蒸らし30秒、後半は細めに注いだ。
          </p>
          <p class="rounded-md bg-[#e6d6c8] p-3 text-sm leading-relaxed">
            昨日より少しマイルドになった。甘みがしっかり出ている。
          </p>
        </div>
      </article>

      <article class="rounded-lg border border-black/10 bg-white p-4 shadow-[0_4px_20px_rgba(0,0,0,0.03)]">
        <div class="mb-4 space-y-1.5">
          <p class="text-xs font-bold text-[#9a8f88]">2023.10.23 07:45</p>
          <h2 class="text-lg font-extrabold text-[#6b3f2b]">グアテマラ アンティグア</h2>
        </div>

        <p class="mb-3 text-xs font-bold text-[#9a8f88]">抽出レシピ</p>
        <div class="flex flex-wrap gap-x-4 gap-y-2 text-sm font-semibold">
          <p>挽き目 30</p>
          <p>16g</p>
          <p>88℃</p>
          <p>02:15</p>
          <p>240ml</p>
        </div>

        <div class="my-4 h-px bg-black/10"></div>

        <div class="flex gap-5">
          <section class="flex-1">
            <p class="mb-3 text-xs font-bold text-[#9a8f88]">味のバランス</p>
            <div class="flex justify-between">
              <% [["酸味", "40%"], ["苦味", "80%"], ["甘み", "50%"], ["とろみ", "70%"], ["雑味", "20%"]].each do |label, height| %>
                <div class="flex flex-1 flex-col items-center gap-2">
                  <div class="relative h-12 w-2 overflow-hidden rounded-full bg-[#e6d6c8]">
                    <div class="absolute bottom-0 left-0 right-0 rounded-full bg-[#c77a4a]" style="height: <%= height %>"></div>
                  </div>
                  <p class="text-[11px] font-bold text-[#9a8f88]"><%= label %></p>
                </div>
              <% end %>
            </div>
          </section>

          <section class="w-[120px]">
            <p class="mb-3 text-xs font-bold text-[#9a8f88]">フレーバー</p>
            <div class="flex flex-wrap gap-1.5">
              <% ["ナッツ", "スパイス"].each do |flavor| %>
                <span class="rounded bg-[#e6d6c8] px-2 py-1 text-xs font-bold text-[#6b3f2b]"><%= flavor %></span>
              <% end %>
            </div>
          </section>
        </div>

        <div class="my-4 h-px bg-black/10"></div>

        <p class="rounded-md bg-[#e6d6c8] p-3 text-sm leading-relaxed">
          少し雑味が出た。お湯の温度を下げるか、挽き目を粗くしてみる。
        </p>
      </article>
    </main>

    <nav class="sticky bottom-0 z-20 flex h-16 items-center justify-around border-t border-black/10 bg-white shadow-[0_-4px_12px_rgba(0,0,0,0.02)]">
      <%= link_to root_path, class: "flex flex-1 flex-col items-center justify-center gap-1 text-[#9a8f88]" do %>
        <span class="text-lg">🏠</span>
        <span class="text-[10px] font-bold">ホーム</span>
      <% end %>
      <%= link_to records_path, class: "flex flex-1 flex-col items-center justify-center gap-1 text-[#6b3f2b]" do %>
        <span class="text-lg">📖</span>
        <span class="text-[10px] font-bold">記録一覧</span>
      <% end %>
      <div class="relative -top-3 flex flex-1 items-center justify-center">
        <%= link_to new_coffee_record_path, class: "flex h-[52px] w-[52px] items-center justify-center rounded-full bg-[#6b3f2b] text-2xl text-white shadow-[0_4px_12px_rgba(107,63,43,0.3)]" do %>
          +
        <% end %>
      </div>
      <div class="flex flex-1 flex-col items-center justify-center gap-1 text-[#9a8f88]">
        <span class="text-lg">📈</span>
        <span class="text-[10px] font-bold">データ</span>
      </div>
      <%= link_to settings_path, class: "flex flex-1 flex-col items-center justify-center gap-1 text-[#9a8f88]" do %>
        <span class="text-lg">👤</span>
        <span class="text-[10px] font-bold">設定</span>
      <% end %>
    </nav>
  </div>
</div>
